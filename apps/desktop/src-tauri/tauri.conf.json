{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CanvasOS",
  "version": "1.0.0",
  "identifier": "art.canvasos.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @canvasos/web dev",
    "beforeBuildCommand": "pnpm --filter @canvasos/web build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CanvasOS",
        "width": 1600,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' blob: data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' blob: data: https:; connect-src 'self' https: ws:"
    }
  },
  "plugins": {
    "stronghold": {}
  }
}
