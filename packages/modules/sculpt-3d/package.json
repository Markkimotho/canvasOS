{
  "name": "@canvasos/sculpt-3d",
  "version": "1.0.0",
  "private": true,
  "description": "CanvasOS 3D sculpting module",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@canvasos/core": "*",
    "@canvasos/ui": "*",
    "three": "^0.167.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@canvasos/tsconfig": "*",
    "@types/react": "^18.3.0",
    "@types/three": "^0.167.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
